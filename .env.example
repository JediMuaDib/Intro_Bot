# Slack Bot tokens (required)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Channel IDs
CH_INTRODUCTIONS=C0123456789
CH_RELEASES=C0123456789

# Gmail SMTP for failure alerts (use a Gmail App Password)
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# GitHub fallback (optional — avoids rate limits)
GITHUB_TOKEN=ghp_...
