# Slack Bot tokens (required)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Channel IDs
CH_INTRODUCTIONS=C0123456789
CH_RELEASES=C0123456789
CH_MARKETING_DRAFTS=C0123456789

# GitHub fallback (optional)
GITHUB_TOKEN=ghp_...

# X/Twitter API (optional — skip to disable Twitter engine)
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...

# Reddit API (optional — skip to disable Reddit engine)
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USERNAME=...
REDDIT_PASSWORD=...
REDDIT_SUBREDDITS=LocalLLM,privacy,androidapps

# Access control (comma-separated Slack user IDs, optional)
RELEASE_AUTHORIZED_USERS=U0123456789

# Dashboard
DASHBOARD_URL=https://your-app.up.railway.app
PORT=3000
